# 複製成 .env 並填入實際值（.env 不會 commit 進 git）
# ⚠️ 密碼只放這個檔案，別貼進跟 Claude 的對話。

# houseol 登入（自動登入用；店代號/帳號已從登入頁帶入，通常不用改）
HOUSEOL_STORE=H888
HOUSEOL_USER=03039
HOUSEOL_PASS=在這裡填你的密碼

# 簽到完成後推 LINE 的 n8n webhook（對應 workflows/clockin-notify.json）
CLOCKIN_NOTIFY_WEBHOOK=https://primary-production-68428.up.railway.app/webhook/clockin-report

# 1=無視窗背景跑(預設)；除錯想看畫面就設 0
CLOCKIN_HEADLESS=1
