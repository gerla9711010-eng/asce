# 複製成 .env 並填入實際值（.env 不會 commit 進 git）

# Notion
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATA_SOURCE_ID=bcf8f493-4aac-45bf-8223-9b49f29aff63

# publish.py（上架）用 profile/ session，不需要帳密；grab.py（搶單）改用 API 登入，要帳密：
KEIS_USERNAME=你的KEIS帳號
KEIS_PASSWORD=你的KEIS密碼

# 公買搶單 grab.py 用：搶到後推 LINE 的 n8n webhook（可選，不填就只存 grabbed.csv）
KEIS_NOTIFY_WEBHOOK=https://primary-production-68428.up.railway.app/webhook/keis-grab
