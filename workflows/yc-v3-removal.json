      "parameters": {
        "jsCode": "const results = $input.first().json.results || [];\nreturn results.map(p => ({ json: {\n  pageId: p.id,\n  caseName: p.properties?.['案名']?.title?.[0]?.plain_text || '(未命名)',\n  contract_no: (p.properties?.['案件編號']?.rich_text?.[0]?.plain_text || '').toUpperCase(),\n  fbPostUrl: p.properties?.['粉專貼文連結']?.url || '',\n  keisAdId: p.properties?.['KEIS廣告ID']?.number || 0,\n  sourceUrl: p.properties?.['來源連結']?.url || ''\n}})).filter(x => x.json.contract_no);"
      },
