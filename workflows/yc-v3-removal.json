      "parameters": {
        "jsCode": "// 線D：下架後把 KEIS 廣告追蹤那筆標成已結束。沒有 adcase id 就跳過。\n// 上游「可標下架?」已濾掉 markRemoved=false，所以照順序對得起來。\nconst src = $('判定刪除結果').all().map(i => i.json).filter(x => x.markRemoved);\nreturn $input.all().map((_, i) => {\n  const c = src[i] || {};\n  const id = Number(c.keisAdId || 0);\n  return { json: { ...c, keisAdId: id, hasKeisAd: id > 0 } };\n});"
