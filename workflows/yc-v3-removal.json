    {
      "parameters": {
        "jsCode": "const checked = $('判斷是否下架').all().map(i => i.json);\nconst total = checked.length;\nconst removed = checked.filter(x => x.isRemoved);\nconst today = new Date().toLocaleDateString('zh-TW', { timeZone: 'Asia/Taipei' });\nlet outcomes = [];\ntry { outcomes = $('判定刪除結果').all().map(i => i.json); } catch (e) {}\nconst byPage = {}; outcomes.forEach(o => byPage[o.pageId] = o);\nlet text;\nif (total === 0) text = `🌅 下架偵測 ${today}\\n\\n沒有已發布的廣告需要偵測。`;\nelse if (removed.length === 0) text = `🌅 下架偵測 ${today}\\n\\n✅ 檢查 ${total} 筆，全部仍在架上。`;\nelse {\n  const lines = removed.map(r => {\n    const o = byPage[r.pageId] || {};\n    const tag = o.fbDeleteFailed ? `⚠️粉專刪除失敗（${o.fbDeleteError}）→ 狀態未改，請手動刪` : (o.fbDeleted ? '粉專貼文已自動刪除' : '無粉專貼文');\n    return `・${r.caseName}（${r.contract_no}）— ${r.reason}；${tag}`;\n  }).join('\\n');\n  const failCount = removed.filter(r => (byPage[r.pageId] || {}).fbDeleteFailed).length;\n  text = `🚨 下架偵測 ${today}\\n\\n檢查 ${total} 筆，${removed.length} 筆已下架：\\n\\n${lines}` + (failCount ? `\\n\\n⚠️ ${failCount} 筆粉專刪除失敗，需你手動處理。` : '');\n}\nreturn [{ json: { userId: 'Ufab42c56b2eb9b9a9ff18c367b85a6dd', summaryText: text } }];"
      },
