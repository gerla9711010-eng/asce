      "parameters": {
        "jsCode": "// KEIS 搶單通知：收 grab.py POST 進來的 payload，組成 LINE 訊息\nconst body = $input.first().json.body || $input.first().json;\nconst USER_ID = \"Ufab42c56b2eb9b9a9ff18c367b85a6dd\"; // 薛力瑜\n\nlet text;\nif (body.event === 'alert') {\n  text = body.text || '⚠ KEIS 搶單警示';\n} else {\n  const g = body.grabbed || [];\n  const lines = g.map(x => `・${x.name} ${x.phone}｜${x.city} ${x.category} ${x.budget}`).join('\\n');\n  const left = (body.quota_left != null) ? body.quota_left : '?';\n  text = `🎯 KEIS 搶到 ${g.length} 筆（今日剩餘配額 ${left}）\\n\\n${lines}`;\n}\nreturn [{ json: { userId: USER_ID, text } }];\n"
      },
      "id": "eef216b1-aebf-4792-9ab7-6c0f26eef5e5",
      "name": "組 LINE 訊息",
      "type": "n8n-nodes-base.code",
