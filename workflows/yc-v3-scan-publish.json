      "parameters": {
        "jsCode": "// 候選＝在售 + 有照片；依 houseol_created_at 新到舊排序，取前 40 進入判重\nconst body = $input.first().json;\nconst items = body.items || body.data || (Array.isArray(body) ? body : []);\nconst cand = items\n  .filter(x => x && x.is_active === true && Number(x.image_count) > 0 && x.contract_no && Number(x.case_price) > 0 && Number(x.case_price) < 9999)\n  .sort((a, b) => new Date(b.houseol_created_at || b.created_at || 0) - new Date(a.houseol_created_at || a.created_at || 0))\n  .slice(0, 40)\n  .map(x => ({ json: { keisId: x.id, contract_no: String(x.contract_no).toUpperCase(), case_name: x.case_name || '', official_url: x.official_url || '' } }));\nif (cand.length === 0) return [{ json: { _empty: true } }];\nreturn cand;"
