    {
      "parameters": {
        "jsCode": "const raw = $('抓照片 HTML').first().json || {};\nconst html = raw.data || raw.body || '';\nconst ctx = $('整合文案').first().json;\n\nconst og = [];\nconst metaRe = /<meta[^>]*(?:property|name)=[\"'](?:og:image(?::secure_url)?|twitter:image)[\"'][^>]*>/gi;\nlet m;\nwhile ((m = metaRe.exec(html))) {\n  const c = m[0].match(/content=[\"']([^\"']+)[\"']/i);\n  if (c) og.push(c[1]);\n}\n\nconst imgs = [];\nconst imgRe = /<img[^>]*?(?:data-src|data-original|data-lazy|src)=[\"']([^\"']+)[\"']/gi;\nwhile ((m = imgRe.exec(html))) imgs.push(m[1]);\n\n// srcset 也撈（取第一個 URL）\nconst setRe = /(?:data-srcset|srcset)=[\"']([^\"']+)[\"']/gi;\nwhile ((m = setRe.exec(html))) {\n  const first = m[1].split(',')[0].trim().split(/\\s+/)[0];\n  if (first) imgs.push(first);\n}\n\nconst norm = u => (u || '').startsWith('//') ? 'https:' + u : u;\nconst bad = /(logo|icon|avatar|sprite|blank|placeholder|loading|qrcode|\\.svg|badge|banner)/i;\nconst isPhoto = u => /^https?:\\/\\//.test(u) && !bad.test(u) && (/\\.(jpe?g|png|webp)(\\?|$)/i.test(u) || /(yungching|ycimg|kshouse|kinghouse|houseprice|cloudfront|akamai|amazonaws)/i.test(u));\n\nlet list = [...og.map(norm), ...imgs.map(norm)].filter(isPhoto);\nlist = [...new Set(list)].slice(0, 6);\n\nreturn [{ json: { ...ctx, photoUrls: list, photoCount: list.length } }];"
      },
