      "parameters": {
        "jsCode": "const event = $input.first().json.events?.[0] || $input.first().json.body?.events?.[0];\nconst messageText = event?.message?.text || '';\nconst replyToken = event?.replyToken || '';\nconst userId = event?.source?.userId || '';\n\n// 格式：發 YCxxxxxxx（發跟 YC 之間空白可省略，全形半形皆可）\nconst m = messageText.match(/^發[\\s\\u3000]*([A-Za-z]{2}\\d{4,})/);\nif (!m) {\n  return [{ json: {\n    _isError: true,\n    replyToken,\n    replyText: `❌ 指令格式錯誤\\n\\n正確格式：\\n發 YC編號\\n例：發 YC1835328\\n\\n收到：「${messageText}」`\n  }}];\n}\nconst caseId = m[1].toUpperCase();\nreturn [{ json: { _isError: false, caseId, replyToken, userId, rawMessage: messageText } }];"
      },
